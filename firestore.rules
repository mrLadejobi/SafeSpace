rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() { 
      return request.auth != null 
        && request.auth.token.email_verified == true
        && (request.auth.token.email == 'oluwasaanumil@gmail.com' || request.auth.token.email == 'ayoolachristianah218@gmail.com'); 
    }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidMovie(data) {
      return data.keys().hasAll(['title', 'year', 'isCartoon', 'addedBy', 'createdAt', 'isShared'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 500
        && data.year is number
        && data.isCartoon is bool
        && data.addedBy is string && data.addedBy == request.auth.uid
        && data.isShared is bool && data.isShared == true
        && data.createdAt == request.time
        && (!('likedBy' in data) || (data.likedBy is list && data.likedBy.size() <= 2))
        && (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 2500))
        && (!('description' in data) || (data.description is string && data.description.size() <= 2000));
    }

    match /movies/{movieId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.isShared == true;
      
      allow create: if isSignedIn()
        && isValidId(movieId)
        && isValidMovie(incoming())
        && incoming().keys().size() <= 9; // title, year, isCartoon, addedBy, createdAt, isShared, likedBy, imageUrl, description

      allow update: if isSignedIn()
        && (
          // Action: Toggle Like
          (
            incoming().diff(existing()).affectedKeys().hasOnly(['likedBy'])
            && incoming().likedBy is list
            && incoming().likedBy.size() <= 2
            && incoming().title == existing().title
            && incoming().year == existing().year
            && incoming().isCartoon == existing().isCartoon
            && incoming().addedBy == existing().addedBy
            && incoming().isShared == existing().isShared
            && incoming().createdAt == existing().createdAt
          )
        );

      allow delete: if isSignedIn() && existing().addedBy == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read, write: if isSignedIn();
    }

    match /queue/{itemId} {
      allow read, write: if isSignedIn();
    }

    match /settings/{settingId} {
      allow read, write: if isSignedIn();
    }
  }
}
